{
  "carla": {
    "host": "127.0.0.1",
    "port": 2000
  },
  "lidar": {
    "max_range": 50.0,
    "channels": 32,
    "points_per_second": 700000,
    "upper_fov": 10.0,
    "lower_fov": -30.0
  },
  "camera_front": {
    "width": 1280,
    "height": 720,
    "fov": 90.0,
    "x": 1.8,
    "y": 0.0,
    "z": 1.45,
    "pitch": 0.0,
    "yaw": 0.0,
    "roll": 0.0
  },
  "lane_annotations": {
    "distance_m": 40.0,
    "step_m": 1.0,
    "max_side_lanes": 2,
    "projection_margin_px": 50.0,
    "dedupe_distance_px": 2.0,
    "min_segment_points": 2,
    "min_projected_points": 2,
    "min_length_px": 30.0,
    "min_length_m": 1.0,
    "extend_to_bottom_threshold_px": 150.0
  },
  "gt_annotations": {
    "min_lidar_points_in_box": 5
  },
  "dataset_root_dir": "datasets/raw",
  "dataset_viewer": {
    "point_radius": 0.03,
    "gt_line_radius": 0.08,
    "lane_line_thickness": 5.0
  },
  "streaming": {
    "prefix": "carla_streaming",
    "poll_interval_ms": 5,
    "frame_buffer_size_bytes": 1048576,
    "objects_buffer_size_bytes": 4194304,
    "lanes_buffer_size_bytes": 4194304,
    "producer": {
      "sensor_slots": 8,
      "fixed_delta_seconds_hint": 0.05
    },
    "aggregator": {
      "scene_bind": "tcp://*:5555"
    },
    "visualizer": {
      "scene_connect": "tcp://127.0.0.1:5555",
      "ego_line_radius": 0.08,
      "pred_line_radius": 0.08
    }
  }
}
